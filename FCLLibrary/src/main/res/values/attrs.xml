<?xml version="1.0" encoding="utf-8"?>
<resources>
    <attr name="use_theme_color" format="boolean" />
    <attr name="auto_tint" format="boolean" />
    <attr name="text_use_theme_color" format="boolean" />
    <declare-styleable name="FCLView">
        <attr name="use_theme_color" />
    </declare-styleable>
    <declare-styleable name="FCLButton">
        <attr name="ripple" format="boolean" />
        <attr name="shape" format="integer" />
        <attr name="auto_padding" format="boolean" />
    </declare-styleable>
    <declare-styleable name="FCLImageButton">
        <attr name="auto_tint" />
        <attr name="no_padding" format="boolean" />
        <attr name="use_theme_color" />
    </declare-styleable>
    <declare-styleable name="FCLImageView">
        <attr name="auto_src_tint" format="boolean" />
        <attr name="use_theme_color" />
    </declare-styleable>
    <declare-styleable name="FCLTextView">
        <attr name="auto_text_background_tint" format="boolean" />
        <attr name="auto_text_tint" format="boolean" />
        <attr name="use_theme_color" />
    </declare-styleable>
    <declare-styleable name="FCLCheckedTextView">
        <attr name="auto_checked_text_background_tint" format="boolean" />
        <attr name="auto_checked_text_tint" format="boolean" />
    </declare-styleable>
    <declare-styleable name="FCLEditText">
        <attr name="auto_edit_tint" format="boolean" />
    </declare-styleable>
    <declare-styleable name="FCLCheckBox">
        <attr name="auto_hint_tint" format="boolean" />
    </declare-styleable>
    <declare-styleable name="FCLTitleView">
        <attr name="title" format="string" localization="suggested" />
    </declare-styleable>
    <declare-styleable name="FCLTabLayout">
        <attr name="follow_theme" format="boolean" />
    </declare-styleable>
    <declare-styleable name="FCLPreciseSeekBar">
        <attr name="auto_button_tint" format="boolean" />
        <attr name="min_value" format="integer" />
        <attr name="max_value" format="integer" />
    </declare-styleable>
    <declare-styleable name="FCLLinearLayout">
        <attr name="auto_linear_background_tint" format="boolean" />
    </declare-styleable>
    <declare-styleable name="FCLConstraintLayout">
        <attr name="auto_tint"/>
    </declare-styleable>
    <declare-styleable name="FCLAppBarLayout">
        <attr name="auto_tint" />
    </declare-styleable>
    <declare-styleable name="FCLRadioButton">
        <attr name="text_use_theme_color" />
    </declare-styleable>
    <declare-styleable name="FCLNumberSeekBar">
        <attr name="suffix" format="string" />
    </declare-styleable>

    <declare-styleable name="ColorPickerView" parent="ColorPanelView">
        <attr name="cpv_alphaChannelVisible" format="boolean|reference" />
        <attr name="cpv_alphaChannelText" format="string|reference" />
        <attr name="cpv_sliderColor" format="color|reference" />
        <attr name="cpv_borderColor" format="color|reference" />
    </declare-styleable>

    <declare-styleable name="HorizontalListView">
        <attr name="dividerWidth" format="dimension" />
        <attr name="android:divider" />
        <attr name="android:requiresFadingEdge" />
        <attr name="android:fadingEdgeLength" />
    </declare-styleable>
</resources>